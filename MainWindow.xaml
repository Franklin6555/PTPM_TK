<Window x:Class="PTPM_TK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PTPM_TK"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка — поля ввода -->
        <StackPanel Grid.Column="0">

            <TextBlock x:Name="tblockSide1" Text="1-я сторона" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="tbSide1" Height="32" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock x:Name="tblockSide2" Text="2-я сторона" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="tbSide2" Height="32" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock x:Name="tblockSide3" Text="3-я сторона" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="tbSide3" Height="32" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock x:Name="tblockRadius" Text="Радиус" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="tbRadius" Height="32" FontSize="14" Margin="0,0,0,25"/>

            <Button Content="Вычислить" 
                    Height="45" 
                    FontSize="16" 
                    FontWeight="Medium"
                    Click="Calculate_Click"/>
        </StackPanel>

        <!-- Правая колонка — выбор фигуры и результат -->
        <StackPanel Grid.Column="2">

            <GroupBox Header="Вид фигуры" Padding="12" FontSize="14" Margin="0,0,0,20">
                <StackPanel>
                    <RadioButton x:Name="rbRectangle" 
                                 Content="прямоугольник" 
                                 GroupName="FigureType" 
                                 Margin="5,8"
                                 Checked="RadioButton_Checked"/>

                    <RadioButton x:Name="rbCircle" 
                                 Content="круг" 
                                 GroupName="FigureType" 
                                 Margin="5,8"
                                 Checked="RadioButton_Checked"/>

                    <RadioButton x:Name="rbTriangle" 
                                 Content="треугольник" 
                                 GroupName="FigureType" 
                                 Margin="5,8"
                                 Checked="RadioButton_Checked"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Результат" Padding="15" FontSize="14">
                <TextBlock x:Name="tbResult" 
                           Text="Площадь = " 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Height="60"
                           VerticalAlignment="Center"/>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>
